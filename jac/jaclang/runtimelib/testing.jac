import io;
import json;
import re;
import from http.server { BaseHTTPRequestHandler }
import from pathlib { Path }
import from typing { Any }
import from urllib.parse { urlencode }
import type from jaclang.project.config { JacConfig }
import type from jaclang.runtimelib.server { JacAPIServer }

obj TestResponse {
    has status_code: int,
        headers: dict[str, str],
        text: str,
        _json_cache: (dict[str, any] | None) = None;

    def json -> dict[str, any];

    has ok: bool { getter; }
    has data: (dict[str, any] | None) { getter; }
}

obj JacTestClient {
    has _jac_file: str,
        _base_path: str,
        _server: (JacAPIServer | None) = None,
        _handler_class: (type | None) = None,
        _auth_token: (str | None) = None,
        _current_user: (str | None) = None,
        _hot_reloader: (Any | None) = None,
        _config: (JacConfig | None) = None;

    static def from_file(
        jac_file: str,
        base_path: (str | None) = None,
        module_name: (str | None) = None,
        config: (JacConfig | None) = None
    ) -> JacTestClient;

    def _ensure_initialized -> None;
    def get(
        path: str,
        params: (dict[str, any] | None) = None,
        headers: (dict[str, str] | None) = None
    ) -> TestResponse;

    def post(
        path: str,
        json: (dict[str, any] | None) = None,
        headers: (dict[str, str] | None) = None
    ) -> TestResponse;

    def put(
        path: str,
        json: (dict[str, any] | None) = None,
        headers: (dict[str, str] | None) = None
    ) -> TestResponse;

    def request(
        method: str,
        path: str,
        json: (dict[str, any] | None) = None,
        params: (dict[str, any] | None) = None,
        headers: (dict[str, str] | None) = None
    ) -> TestResponse;

    def set_auth_token(token: str) -> None;
    def clear_auth -> None;
    def register_user(username: str, password: str) -> TestResponse;
    def login(username: str, password: str) -> TestResponse;
    def _execute_request(
        method: str,
        path: str,
        body: (bytes | None) = None,
        headers: (dict[str, str] | None) = None
    ) -> TestResponse;

    def _parse_response(raw_response: bytes) -> TestResponse;

    has server: JacAPIServer { getter; }
    has user_manager: any { getter; }

    def reload -> None;
    def close -> None;
}
