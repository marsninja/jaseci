import ast as py_ast;

import from pathlib { Path }
import from jaclang.cli.console { console }

glob _SEEDS: list[str] = [
         "jaclang.jac0core.jaclib",
         "jaclang.jac0core.runtime",
         "jaclang.jac0core.archetype",
         "jaclang.runtimelib.server",
         "jaclang.runtimelib.memory",
         "jaclang.runtimelib.serializer",
         "jaclang.runtimelib.changeset",
         "jaclang.runtimelib.builtin"
     ],
     _BYLLM_SEEDS: list[str] = [
         "jaclang.byllm",
         "jaclang.byllm.lib",
         "jaclang.byllm.plugin",
         "jaclang.byllm.plugin_config"
     ],
     _DENY_PREFIXES: list[str] = [
         "jaclang.compiler",
         "jaclang.meta_importer",
         "jaclang.langserve",
         "jaclang.utils",
         "jaclang.scale",
         "jaclang.cli",
         "jaclang.vendor",
         "jaclang.byllm.cli",
         "jaclang.jac0core.passes",
         "jaclang.jac0core.parser",
         "jaclang.jac0core.program",
         "jaclang.jac0core.compiler",
         "jaclang.jac0core.unitree",
         "jaclang.jac0core.bccache",
         "jaclang.jac0core.jir",
         "jaclang.jac0core.native_accel",
         "jaclang.jac0core.native_marshal",
         "jaclang.jac0core.interop_bridge",
         "jaclang.jac0core.gen_jir_registry",
         "jaclang.jac0core.gen_uni_dispatch",
         "jaclang.jac0core.cli_boot",
         "jaclang.runtimelib.client",
         "jaclang.runtimelib.hmr",
         "jaclang.runtimelib.watcher",
         "jaclang.runtimelib.cl_test_runner",
         "jaclang.runtimelib.preact_entry",
         "jaclang.runtimelib.react_entry",
         "jaclang.runtimelib.solid_entry"
     ],
     _ALLOW_EXACT: list[str] = ["jaclang.cli.console", "jaclang.cli.banners"],
     _VENDORED_INIT: str = '''"""Vendored jaclang runtime for an ejected app.

Generated by `jac eject`: the compiled runtime closure only -- no compiler,
no CLI, no plugin entry-point discovery. Regenerate by re-running `jac eject`.
"""

import sys

import jaclang.jac0core.runtime as _runtime_mod

from jaclang.jac0core.runtime import (
    JacRuntime,
    JacRuntimeImpl,
    JacRuntimeInterface,
    plugin_manager,
)

sys.modules.setdefault("jaclang.runtimelib.runtime", _runtime_mod)

plugin_manager.register(JacRuntimeImpl)

__all__ = ["JacRuntime", "JacRuntimeImpl", "JacRuntimeInterface", "plugin_manager"]
''',
     _BYLLM_INIT_EXTRA: str = '''

def _register_vendored_byllm_provider():
    """Register the vendored byLLM provider (the `by llm()` feature)."""
    try:
        from jaclang.byllm.plugin import JacRuntime as JacByllmRuntime
        from jaclang.byllm.plugin_config import JacByllmPluginConfig
    except Exception as exc:
        import warnings

        warnings.warn(f"Vendored byLLM provider unavailable: {exc}", stacklevel=2)
        return
    for _provider in (JacByllmRuntime, JacByllmPluginConfig):
        if not plugin_manager.is_registered(_provider):
            plugin_manager.register(_provider)


_register_vendored_byllm_provider()
''',
     _CLOSURE_CACHE: dict[tuple, tuple] = {};


def _pkg_root -> Path {
    import jaclang;
    return Path(str(jaclang.__file__)).parent;
}


def _denied(mod: str) -> bool {
    for allowed in _ALLOW_EXACT {
        if mod == allowed {
            return False;
        }
    }
    for pref in _DENY_PREFIXES {
        if (mod == pref) or mod.startswith(pref + ".") {
            return True;
        }
    }
    return False;
}


def _module_to_file(pkg_root: Path, mod: str) -> Path | None {
    if not mod.startswith("jaclang.") {
        return None;
    }
    rel = mod[len("jaclang."):].replace(".", "/");
    for cand in [
        pkg_root / (rel + ".jac"),
        pkg_root / (rel + ".py"),
        pkg_root / rel / "__init__.jac",
        pkg_root / rel / "__init__.py"
    ] {
        if cand.exists() {
            return cand;
        }
    }
    return None;
}


def scan_jaclang_imports(py_src: str) -> set {
    found: set = set();
    try {
        tree = py_ast.parse(py_src);
    } except Exception {
        return found;
    }
    stack: list = [(tree, False)];
    while stack {
        (nd, in_tc) = stack.pop();
        for child in py_ast.iter_child_nodes(nd) {
            tc = in_tc;
            if isinstance(child, py_ast.If)
            and ("TYPE_CHECKING" in py_ast.unparse(child.test)) {
                tc = True;
            }
            if (not tc) and isinstance(child, py_ast.Import) {
                for alias in child.names {
                    if alias.name.startswith("jaclang.") {
                        found.add(alias.name);
                    }
                }
            } elif (not tc) and isinstance(child, py_ast.ImportFrom) {
                if child.module and (child.level == 0) {
                    mod = str(child.module);
                    if (mod == "jaclang") or mod.startswith("jaclang.") {
                        if mod != "jaclang" {
                            found.add(mod);
                        }
                        for alias in child.names {
                            found.add(mod + "." + alias.name);
                        }
                    }
                }
            }
            stack.append((child, tc));
        }
    }
    return found;
}


def _compile_runtime_module(pkg_root: Path, path: Path) -> str | None {
    if path.suffix == ".py" {
        return path.read_text(encoding="utf-8");
    }
    if str(path).startswith(str(pkg_root / "jac0core")) {
        import from jaclang.jac0 { compile_jac, discover_impl_files }
        jac_source = path.read_text(encoding="utf-8");
        impl_sources: list = [];
        for impl_path in discover_impl_files(str(path)) {
            impl_sources.append(
                (Path(impl_path).read_text(encoding="utf-8"), impl_path)
            );
        }
        return compile_jac(jac_source, str(path), impl_sources=impl_sources or None);
    }
    import from jaclang.jac0core.program { JacProgram }
    prog = JacProgram();
    ir = prog.compile(file_path=str(path));
    if prog.errors_had {
        for err in prog.errors_had {
            console.error(f"  runtime vendor: {path.name}: {err}");
        }
        return None;
    }
    py_out = str(ir.gen.py or "");
    if not py_out.strip() {
        console.error(
            f"  runtime vendor: {path.name}: compiler produced no Python "
            "output (and reported no errors); aborting."
        );
        return None;
    }
    return py_out;
}


def vendor_runtime(
    backend_dir: Path,
    user_codes: list,
    include_byllm: bool = False,
    extra_seeds: (list | None) = None
) -> int {
    pkg_root = _pkg_root();
    seeds: list = list(_SEEDS);
    if include_byllm {
        seeds.extend(_BYLLM_SEEDS);
    }
    if extra_seeds {
        seeds.extend([str(s) for s in extra_seeds]);
    }
    for code in user_codes {
        for imp in scan_jaclang_imports(str(code)) {
            if not _denied(imp) {
                seeds.append(imp);
            }
        }
    }

    sources: dict[str, str] = {};
    dests: dict[str, Path] = {};
    cache_key = (str(pkg_root), tuple(sorted(set(seeds))));
    if cache_key in _CLOSURE_CACHE {
        (sources, dests) = _CLOSURE_CACHE[cache_key];
    } else {
        queue: list[str] = [str(s) for s in seeds];
        while queue {
            mod = str(queue.pop(0));
            if (mod in sources) or (mod == "jaclang") or _denied(mod) {
                continue;
            }
            src_file = _module_to_file(pkg_root, mod);
            if src_file is None {
                continue;
            }
            parts = mod.split(".");
            for i in range(2, len(parts)) {
                parent = ".".join(parts[:i]);
                if parent not in sources and parent not in queue {
                    queue.append(parent);
                }
            }
            compiled = _compile_runtime_module(pkg_root, src_file);
            if compiled is None {
                return -1;
            }

            sources[mod] = compiled.replace(str(pkg_root), "jaclang");
            dests[mod] = src_file;
            for imp in scan_jaclang_imports(compiled) {
                dep = str(imp);
                if (not _denied(dep)) and (dep not in sources) and (dep not in queue) {
                    queue.append(dep);
                }
            }
        }
        _CLOSURE_CACHE[cache_key] = (sources, dests);
    }

    pkg_dir = backend_dir / "jaclang";
    pkg_dir.mkdir(parents=True, exist_ok=True);
    init_src = _VENDORED_INIT + (_BYLLM_INIT_EXTRA if include_byllm else "");
    (pkg_dir / "__init__.py").write_text(init_src, encoding="utf-8");

    for (mod, src) in sorted(sources.items()) {
        try {
            py_ast.parse(src);
        } except Exception as e {
            console.error(
                f"  runtime vendor: generated source for {mod} is not valid "
                f"Python ({e}); aborting."
            );
            return -1;
        }
        rel = mod[len("jaclang."):].replace(".", "/");
        if dests[mod].stem == "__init__" {
            out_path = pkg_dir / rel / "__init__.py";
        } else {
            out_path = pkg_dir / (rel + ".py");
        }
        out_path.parent.mkdir(parents=True, exist_ok=True);
        out_path.write_text(src, encoding="utf-8");
    }

    for sub in sorted(pkg_dir.rglob("*")) {
        if sub.is_dir() and not (sub / "__init__.py").exists() {
            (sub / "__init__.py").write_text("", encoding="utf-8");
        }
    }

    return len(sources);
}


def llm_requirements -> list[str] {
    import from jaclang.project.capabilities { CAPABILITY_SPECS }
    spec = CAPABILITY_SPECS.get("llm", {});
    deps: dict = dict(spec.get("deps", {})) if isinstance(spec, dict) else {};
    return sorted([f"{name}{rng}" for (name, rng) in deps.items()]);
}
