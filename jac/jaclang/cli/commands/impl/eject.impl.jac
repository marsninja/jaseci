import ast;
import shutil;
import json;
import from pathlib { Path }
import from jaclang.cli.console { console }
import from jaclang.jac0core.ext_registry {
    base_stem,
    is_client_module,
    is_native_module,
    is_annex
}

glob _SKIP_DIRS: set = {
         ".jac",
         ".git",
         ".venv",
         "venv",
         "node_modules",
         "__pycache__",
         ".mypy_cache",
         ".pytest_cache",
         "dist",
         "build"
     };


def load_eject_project_metadata(src: Path) -> dict {
    toml_path = src / "jac.toml";
    if not toml_path.exists() {
        raise FileNotFoundError(f"No jac.toml found in {src}");
    }
    import from jaclang.jac0core.helpers { read_toml_with_encoding }
    toml_data = read_toml_with_encoding(str(toml_path));
    project_section = toml_data.get("project", {});
    raw_name = project_section.get("name", "") or "";

    if (not raw_name) or ("{{" in raw_name) {
        project_name = src.name;
    } else {
        project_name = raw_name;
    }
    entry_point = project_section.get("entry-point", "main.jac");
    entry_module = _strip_jac_suffix(Path(entry_point).name);
    return {
        "project_name": project_name,
        "entry_point": entry_point,
        "entry_module": entry_module,
        "toml_data": toml_data,

    };
}


impl eject(source: str = ".", output: str = "", force: bool = False) -> int {
    src = Path(source).resolve();
    if not src.exists() or not src.is_dir() {
        console.error(f"Source directory does not exist: {src}");
        return 1;
    }

    try {
        metadata = load_eject_project_metadata(src);
    } except FileNotFoundError as e {
        console.error(str(e));
        console.print(
            "  Eject requires a Jac project (a directory containing jac.toml).",
            style="muted"
        );
        return 1;
    } except RuntimeError as e {
        console.error(str(e));
        return 1;
    }
    project_name = str(metadata["project_name"]);
    entry_module = str(metadata["entry_module"]);
    toml_data = dict(metadata["toml_data"]);

    eject_cfg = toml_data.get("eject", {});
    if output {
        out = Path(output).resolve();
    } else {
        out = (src / str(eject_cfg.get("output", "ejected"))).resolve();
    }
    if out == src {
        console.error("Output directory cannot be the same as the source directory.");
        return 1;
    }

    marker = out / ".jac-ejected";
    if out.exists() {
        if force or marker.exists() {
            try {
                shutil.rmtree(out);
            } except Exception as e {
                console.error(f"Failed to remove existing output directory: {e}");
                return 1;
            }
        } else {
            console.error(f"Output directory already exists: {out}");
            console.print(
                "  It was not created by eject. Use --force to overwrite.",
                style="muted"
            );
            return 1;
        }
    }

    out.mkdir(parents=True);

    marker.write_text("Generated by `jac eject`. Safe to delete.\n", encoding="utf-8");
    backend_dir = out / "backend";
    frontend_dir = out / "frontend";
    frontend_src_dir = frontend_dir / "src";
    backend_dir.mkdir(parents=True);
    frontend_src_dir.mkdir(parents=True);

    console.print(f"\n📦 Ejecting '{project_name}' → FastAPI app", style="bold cyan");
    console.print(f"  Source: {src}");
    console.print(f"  Output: {out}\n");

    eject_roots = _find_eject_roots(src, out);
    jac_files = [
        f
        for f in _collect_jac_files(src)
        if (out not in Path(str(f)).parents)
        and not _under_any(Path(str(f)), eject_roots)
    ];
    if not jac_files {
        console.error("No .jac source files found to eject.");
        return 1;
    }

    import from jaclang.jac0core.program { JacProgram }
    import from jaclang.runtimelib.client_surface { prepend_active_runtime_globals }

    import jaclang.jac0core.unitree as uni;
    import from jaclang.jac0core.constant { SymbolType }

    js_count = 0;

    entry_has_app = False;
    error_count = 0;
    reserved: set = {"main"};
    compiled: list = [];
    remap: dict = {};
    walkers: list = [];
    functions: list = [];
    for jac_file in jac_files {
        rel = Path(str(jac_file)).relative_to(src);
        try {
            prog = JacProgram();
            ir = prog.compile(file_path=str(jac_file));
        } except Exception as e {
            console.error(f"  ✗ {rel}: compile failed: {e}");
            error_count += 1;
            continue;
        }
        if prog.errors_had {
            for err in prog.errors_had {
                console.error(f"  ✗ {rel}: {err}");
            }
            error_count += 1;
            continue;
        }

        py_code = ir.gen.py or "";
        js_code = ir.gen.js or "";

        if js_code.strip() {
            js_rel = _to_js_rel_path(rel);
            js_out = frontend_src_dir / js_rel;
            js_out.parent.mkdir(parents=True, exist_ok=True);
            js_out.write_text(
                prepend_active_runtime_globals(js_code), encoding="utf-8"
            );
            js_count += 1;

            stem = str(_strip_jac_suffix(rel.name));
            if (len(rel.parent.parts) == 0)
            and (stem == entry_module)
            and _js_exports_app(js_code) {
                entry_has_app = True;
            }
        }

        stem = str(_strip_jac_suffix(rel.name));
        parent_parts = [str(p) for p in rel.parent.parts];
        if (len(parent_parts) == 0) and (stem in reserved) {
            bmod = f"_jac_{stem}";
            remap[stem] = bmod;
        } else {
            bmod = ".".join(parent_parts + [stem]);
        }
        is_client = is_client_module(rel.name);
        is_native = is_native_module(rel.name);
        server = _is_meaningful_python(py_code) and (not is_client) and (not is_native);

        if server {
            for item in ir.body {
                if isinstance(item, uni.Archetype)
                and item.sym_category == SymbolType.WALKER_ARCH {
                    walkers.append(
                        {
                            "name": str(item.name.sym_name),
                            "module": bmod,
                            "pub": _has_pub_access(item)
                        }
                    );
                } elif isinstance(item, uni.Ability) and item.name_ref is not None {
                    fn_name = str(item.name_ref.sym_name);
                    if fn_name.startswith("_") {
                        continue;
                    }
                    functions.append(
                        {"name": fn_name, "module": bmod, "pub": _has_pub_access(item)}
                    );
                }
            }
        }
        compiled.append(
            {
                "module": bmod,
                "orig": ".".join(parent_parts + [stem]),
                "py": py_code,
                "server": server
            }
        );
        console.print(f"  ✔ {rel}", style="success");
    }

    if error_count > 0 {
        console.error(
            f"\n{error_count} file(s) failed to compile. Output is incomplete."
        );
        return 1;
    }

    db_cfg = dict(eject_cfg.get("db", {}));
    project_deps = _harvest_python_deps(toml_data);
    env_files = [
        name
        for name in [".env", ".env.example"]
        if (src / name).is_file()
    ];

    entry_bmod = "";
    reach = _entry_reachable_modules(compiled, entry_module);
    if reach is None {
        console.warning(
            f"  entry module '{entry_module}' not found among compiled "
            "modules; exposing endpoints from every module."
        );
    } else {
        reachable = reach["reachable"];
        orig_by_bmod: dict = {};
        for unit in compiled {
            orig_by_bmod[str(unit["module"])] = str(unit["orig"]);
            if (str(unit["orig"]) == str(reach["entry"])) and unit["server"] {
                entry_bmod = str(unit["module"]);
            }
        }
        dropped: set = set();
        walkers = _keep_reachable(walkers, orig_by_bmod, reachable, dropped);
        functions = _keep_reachable(functions, orig_by_bmod, reachable, dropped);
        if dropped {
            console.print(
                "  ○ not imported by the entry module (kept as plain modules, "
                "no endpoints): " + ", ".join(sorted(dropped)),
                style="muted"
            );
        }
    }

    import from jaclang.cli.commands.eject_targets.backend { emit_backend }
    rc = emit_backend(
        backend_dir,
        project_name,
        compiled,
        walkers,
        functions,
        remap,
        db_cfg,
        project_deps,
        len(env_files) > 0,
        entry_bmod
    );
    if rc != 0 {
        return rc;
    }

    _emit_backend_jac_toml(backend_dir, project_name, toml_data);

    has_frontend = entry_has_app;
    if has_frontend {
        runtime_copied = _copy_client_runtime(src, frontend_dir);
        _emit_package_json(frontend_dir, project_name, toml_data);
        _emit_vite_config(frontend_dir, runtime_copied, toml_data);
        entry_copied = _copy_compiled_entry(src, frontend_src_dir);
        if not entry_copied {
            _emit_entry_js(frontend_src_dir, entry_module);
        }
        _emit_index_html(frontend_dir, project_name, entry_copied);
    } else {
        console.warning(
            f"  No client `app` component in entry module '{entry_module}'; "
            "emitting a backend-only app (skipping the frontend scaffold)."
        );
    }

    _copy_data_files(
        src, out, backend_dir, frontend_src_dir, frontend_dir, has_frontend, eject_roots
    );

    if not has_frontend {
        try {
            shutil.rmtree(frontend_dir);
        } except Exception {
            _ = 0;
        }
    }

    for name in env_files {
        shutil.copy2(src / name, out / name);
    }
    if env_files {
        console.print("  ✔ " + ", ".join(env_files), style="success");
    }
    _emit_makefile(out, has_frontend);
    _emit_readme(out, project_name, has_frontend, env_files);

    console.print();
    console.success(f"Ejected '{project_name}' → {out}");
    fe_summary = f"   frontend: {js_count} JS module(s)" if has_frontend else "";
    console.print(
        f"  backend: {len(walkers)} walker(s), {len(functions)} function(s)"
        f"{fe_summary}",
        style="muted"
    );
    console.print(
        "  self-contained: the jaclang runtime is vendored into backend/; "
        "no jaclang package install needed.",
        style="muted"
    );
    console.print();
    console.print("Next steps:", style="bold");
    console.print(f"  cd {out}");
    if (".env.example" in env_files) and (".env" not in env_files) {
        console.print("  cp .env.example .env");
    }
    console.print("  make install");
    console.print("  make dev");
    console.print();
    return 0;
}


def _find_eject_roots(src: Path, out: Path) -> set {
    roots: set = set();
    for marker in src.rglob(".jac-ejected") {
        marker_dir = marker.parent;
        if marker_dir != out {
            roots.add(marker_dir);
        }
    }
    return roots;
}


def _under_any(path: Path, roots: set) -> bool {
    for base in roots {
        if (path == base) or (base in path.parents) {
            return True;
        }
    }
    return False;
}


def _collect_jac_files(src: Path) -> list[Path] {
    results: list[Path] = [];
    all_files = list(src.rglob("*.jac"));
    all_files.sort();
    for path in all_files {
        if not path.is_file() {
            continue;
        }
        rel = path.relative_to(src);
        if _dir_excluded(rel) {
            continue;
        }
        name = path.name;
        if is_annex(name) {
            continue;
        }
        results.append(path);
    }
    return results;
}


def _dir_excluded(rel: Path) -> bool {
    rel_parts = list(rel.parts);
    for i in range(len(rel_parts) - 1) {
        part = rel_parts[i];
        if (part in _SKIP_DIRS) or part.startswith(".") {
            return True;
        }
    }
    return False;
}


def _strip_jac_suffix(name: str) -> str {
    return base_stem(name);
}


def _to_js_rel_path(rel: Path) -> Path {
    return rel.parent / (_strip_jac_suffix(rel.name) + ".js");
}


def _js_exports_app(js_code: str) -> bool {
    for raw in js_code.splitlines() {
        line = raw.strip();
        if not line.startswith("export") {
            continue;
        }
        compact = line.replace(" ", "");
        if ("{app}" in compact)
        or ("{app," in compact)
        or (",app}" in compact)
        or (",app," in compact)
        or ("asapp}" in compact)
        or ("asapp," in compact) {
            return True;
        }
        if compact.startswith("exportconstapp=")
        or compact.startswith("exportfunctionapp(")
        or compact.startswith("exportletapp=")
        or compact.startswith("exportvarapp=")
        or compact.startswith("exportasyncfunctionapp(") {
            return True;
        }
    }
    return False;
}


def _is_meaningful_python(py_code: str) -> bool {
    if not py_code.strip() {
        return False;
    }
    try {
        tree = ast.parse(py_code);
    } except Exception {
        return True;
    }
    for node in tree.body {
        if isinstance(node, (ast.Import, ast.ImportFrom)) {
            continue;
        }
        if isinstance(node, ast.Expr)
        and isinstance(node.value, ast.Constant)
        and isinstance(node.value.value, str) {
            continue;
        }
        return True;
    }
    return False;
}


def _emit_package_json(frontend_dir: Path, project_name: str, toml_data: dict) {
    npm_deps_root = toml_data.get("dependencies", {}).get("npm", {});
    deps: dict[str, str] = {};
    dev_deps: dict[str, str] = {};
    for (k, v) in npm_deps_root.items() {
        if k == "dev" {
            if isinstance(v, dict) {
                for (dk, dv) in v.items() {
                    if isinstance(dv, str) {
                        dev_deps[dk] = dv;
                    }
                }
            }
        } elif isinstance(v, str) {
            deps[k] = v;
        }
    }

    if "vite" not in dev_deps and "vite" not in deps {
        dev_deps["vite"] = "^5.0.0";
    }
    pkg = {
        "name": project_name.lower().replace("_", "-").replace(" ", "-"),
        "version": "0.1.0",
        "private": True,
        "type": "module",
        "scripts": {"dev": "vite", "build": "vite build", "preview": "vite preview"},
        "dependencies": deps,
        "devDependencies": dev_deps
    };
    (frontend_dir / "package.json").write_text(
        json.dumps(pkg, indent=2) + "\n", encoding="utf-8"
    );
}


def _emit_vite_config(frontend_dir: Path, runtime_copied: bool, toml_data: dict) {
    vite_cfg = dict(toml_data.get("plugins", {}).get("client", {}).get("vite", {}));
    lib_imports = [str(i) for i in vite_cfg.get("lib_imports", [])];
    plugins = [str(p) for p in vite_cfg.get("plugins", [])];

    header: list[str] = [
        'import path from "path";',
        'import { fileURLToPath } from "url";'
    ];
    for lib_import in lib_imports {
        line = lib_import if lib_import.rstrip().endswith(";") else (lib_import + ";");
        header.append(line);
    }
    header += [
        '',
        'const __dirname = path.dirname(fileURLToPath(import.meta.url));',
        'const _backendPort = process.env.BACKEND_PORT || "8000";',
        '// Target 127.0.0.1, not "localhost": uvicorn binds IPv4-only, but',
        '// "localhost" also resolves to ::1, and the proxy stalls (ETIMEDOUT)',
        '// on the dead IPv6 address before falling back.',
        'const _backendHost = process.env.BACKEND_HOST || "127.0.0.1";',
        'const _backend = `http://${_backendHost}:${_backendPort}`;',
        '',
        '/** @type {import("vite").UserConfig} */',
        'export default {',

    ];
    plugins_block: list[str] = [];
    if plugins {
        plugins_block.append('  plugins: [');
        for plugin in plugins {
            plugins_block.append('    ' + plugin + ',');
        }
        plugins_block.append('  ],');
    }
    resolve_block: list[str] = [];
    if runtime_copied {
        resolve_block = [
            '  resolve: {',
            '    alias: {',
            '      "@jac/runtime": path.resolve(__dirname, "src/__jac_runtime.js")',
            '    }',
            '  },',

        ];
    }
    server_block: list[str] = [
        '  server: {',
        '    proxy: {',
        '      "/walker":    _backend,',
        '      "/walkers":   _backend,',
        '      "/function":  _backend,',
        '      "/functions": _backend,',
        '      "/user":      _backend,',
        '      "/cl":        _backend,',
        '      "/docs":      _backend,',
        '      "/openapi.json": _backend',
        '    }',
        '  }',
        '};',
        ''
    ];
    lines: list[str] = header + plugins_block + resolve_block + server_block;
    (frontend_dir / "vite.config.js").write_text("\n".join(lines), encoding="utf-8");
}


def _copy_client_runtime(src: Path, frontend_root: Path) -> bool {
    runtime_src = src / ".jac" / "client" / "compiled" / "client_runtime.js";
    if not runtime_src.exists() {
        console.warning(
            "  No .jac/client/compiled/client_runtime.js found; "
            "@jac/runtime imports will be unresolved. "
            "Run `jac install` (or any `jac start`) before `jac eject` "
            "to build the client runtime."
        );
        return False;
    }
    dest = frontend_root / "src" / "__jac_runtime.js";
    dest.parent.mkdir(parents=True, exist_ok=True);
    map_src = runtime_src.with_suffix(".js.map");
    has_map = map_src.exists();
    try {
        content = runtime_src.read_text(encoding="utf-8");
    } except Exception as e {
        console.warning(f"Failed to read client_runtime.js: {e}");
        return False;
    }

    content = _fix_sourcemap_ref(content, "__jac_runtime.js.map", has_map);
    dest.write_text(content, encoding="utf-8");
    if has_map {
        try {
            shutil.copy2(map_src, dest.with_suffix(".js.map"));
        } except Exception {
            _ = 0;
        }
    }

    for sibling in sorted(runtime_src.parent.glob("client_runtime*")) {
        if sibling.name in ["client_runtime.js", "client_runtime.js.map"] {
            continue;
        }
        try {
            shutil.copy2(sibling, dest.parent / sibling.name);
        } except Exception {
            _ = 0;
        }
    }
    console.print("  ✔ @jac/runtime", style="success");
    return True;
}


def _copy_compiled_entry(src: Path, frontend_src_dir: Path) -> bool {
    compiled_dir = src / ".jac" / "client" / "compiled";
    entry_src = compiled_dir / "_entry.js";
    routes_src = compiled_dir / "_routes.js";
    if not entry_src.exists() or not routes_src.exists() {
        return False;
    }
    try {
        shutil.copy2(entry_src, frontend_src_dir / "_entry.js");
        shutil.copy2(routes_src, frontend_src_dir / "_routes.js");
    } except Exception as e {
        console.warning(f"  Failed to copy the compiled client entry: {e}");
        return False;
    }
    console.print("  ✔ client entry + pages routing", style="success");
    return True;
}


def _copy_data_files(
    src: Path,
    out: Path,
    backend_dir: Path,
    frontend_src_dir: Path,
    frontend_root: Path,
    has_frontend: bool,
    eject_roots: set
) {
    copied = False;
    for path in src.rglob("*") {
        if not path.is_file() {
            continue;
        }
        if out in path.parents {
            continue;
        }
        if _under_any(path, eject_roots) {
            continue;
        }
        rel = path.relative_to(src);
        if _dir_excluded(rel) {
            continue;
        }
        rel_parts = list(rel.parts);
        if path.name.startswith(".") {
            continue;
        }
        if path.suffix == ".jac" {
            continue;
        }
        if str(rel) == "jac.toml" {
            continue;
        }
        if rel_parts and (rel_parts[0] == "public") {
            if not has_frontend {
                continue;
            }
            dest = frontend_root / rel;
            dest.parent.mkdir(parents=True, exist_ok=True);
            shutil.copy2(path, dest);
            copied = True;
            continue;
        }
        if has_frontend and _is_frontend_asset(rel) {
            dest_f = frontend_src_dir / rel;
            dest_f.parent.mkdir(parents=True, exist_ok=True);
            shutil.copy2(path, dest_f);
            static_rels = [rel];
            if rel_parts and (rel_parts[0] == "assets") and (len(rel_parts) > 1) {
                static_rels.append(Path(*rel_parts[1:]));
            }
            for static_rel in static_rels {
                dest_s = frontend_root / "public" / "static" / static_rel;
                dest_s.parent.mkdir(parents=True, exist_ok=True);
                shutil.copy2(path, dest_s);
            }
        } else {
            dest_b = backend_dir / rel;
            dest_b.parent.mkdir(parents=True, exist_ok=True);
            shutil.copy2(path, dest_b);
        }
        copied = True;
    }
    if copied {
        console.print("  ✔ resources", style="success");
    }
}


glob _FRONTEND_ASSET_EXTS: set = {
         ".css",
         ".scss",
         ".sass",
         ".less",
         ".png",
         ".jpg",
         ".jpeg",
         ".gif",
         ".svg",
         ".webp",
         ".avif",
         ".ico",
         ".bmp",
         ".woff",
         ".woff2",
         ".ttf",
         ".otf",
         ".eot",
         ".mp4",
         ".webm",
         ".mp3",
         ".wav",
         ".ogg"
     };


def _is_frontend_asset(rel: Path) -> bool {
    parts = list(rel.parts);
    if parts and (parts[0] == "assets") {
        return True;
    }
    return rel.suffix.lower() in _FRONTEND_ASSET_EXTS;
}


def _fix_sourcemap_ref(js_code: str, map_name: str, has_map: bool) -> str {
    out_lines: list[str] = [];
    for line in js_code.splitlines() {
        if line.strip().startswith("//# sourceMappingURL=") {
            if has_map {
                out_lines.append("//# sourceMappingURL=" + map_name);
            }
            continue;
        }
        out_lines.append(line);
    }
    return "\n".join(out_lines);
}


def _emit_index_html(
    frontend_dir: Path, project_name: str, entry_copied: bool = False
) {
    entry_src = "/src/_entry.js" if entry_copied else "/src/__jac_entry.js";
    lines: list[str] = [
        '<!doctype html>',
        '<html lang="en">',
        '  <head>',
        '    <meta charset="UTF-8" />',
        '    <meta name="viewport" content="width=device-width, initial-scale=1.0" />',
        f'    <title>{project_name}</title>',
        '  </head>',
        '  <body>',
        '    <div id="root"></div>',
        f'    <script type="module" src="{entry_src}"></script>',
        '  </body>',
        '</html>',
        ''
    ];
    (frontend_dir / "index.html").write_text("\n".join(lines), encoding="utf-8");
}


def _emit_entry_js(frontend_src_dir: Path, entry_module: str) {
    import from jaclang.compiler.passes.ecmascript.backends.registry {
        resolve_active_backend
    }
    backend = resolve_active_backend();
    (frontend_src_dir / "__jac_entry.js").write_text(
        backend.build_entry_script(entry_module), encoding="utf-8"
    );
}


def _keep_reachable(
    items: list, orig_by_bmod: dict, reachable: set, dropped: set
) -> list {
    kept: list = [];
    for it in items {
        orig = orig_by_bmod.get(str(it["module"]));
        if orig in reachable {
            kept.append(it);
        } else {
            dropped.add(str(orig));
        }
    }
    return kept;
}


def _entry_reachable_modules(compiled: list, entry_module: str) -> (dict | None) {
    units_by_orig: dict = {};
    for unit in compiled {
        units_by_orig[str(unit["orig"])] = unit;
    }
    entry = "";
    if entry_module in units_by_orig {
        entry = entry_module;
    } else {
        for name in sorted(units_by_orig.keys()) {
            if name.endswith("." + entry_module) {
                entry = name;
                break;
            }
        }
    }
    if not entry {
        return None;
    }
    known: set = set(units_by_orig.keys());
    reachable: set = set();
    queue: list = [entry];
    while queue {
        cur = str(queue.pop(0));
        if cur in reachable {
            continue;
        }
        reachable.add(cur);
        deps = _py_import_targets(str(units_by_orig[cur]["py"]), cur, known);
        for dep in sorted(deps) {
            if dep not in reachable {
                queue.append(dep);
            }
        }
    }
    return {"reachable": reachable, "entry": entry};
}


def _py_import_targets(py_code: str, mod_name: str, known: set) -> set {
    targets: set = set();
    try {
        tree = ast.parse(py_code);
    } except Exception {
        return targets;
    }
    pkg_parts = mod_name.split(".")[:-1];
    for node in ast.walk(tree) {
        if isinstance(node, ast.ImportFrom) {
            if node.level > 0 {
                keep = len(pkg_parts) - (node.level - 1);
                if keep < 0 {
                    continue;
                }
                base_parts = list(pkg_parts[:keep]);
                if node.module {
                    base_parts.append(str(node.module));
                }
                base = ".".join(base_parts);
            } else {
                base = str(node.module or "");
            }
            if base in known {
                targets.add(base);
            }
            for alias in node.names {
                cand = (base + "." + str(alias.name)) if base else str(alias.name);
                if cand in known {
                    targets.add(cand);
                }
            }
        } elif isinstance(node, ast.Import) {
            for alias in node.names {
                parts = str(alias.name).split(".");
                for i in range(1, len(parts) + 1) {
                    prefix = ".".join(parts[:i]);
                    if prefix in known {
                        targets.add(prefix);
                    }
                }
            }
        }
    }
    return targets;
}


glob _NON_PIP_DEPS: set = {"npm", "jaclang", "byllm"};


def _harvest_python_deps(toml_data: dict) -> list[str] {
    import from jaclang.project.dependencies { make_pip_spec }
    deps = toml_data.get("dependencies", {});
    if not isinstance(deps, dict) {
        return [];
    }
    reqs: list[str] = [];
    for (name, spec) in deps.items() {
        pkg = str(name);
        if pkg.lower() in _NON_PIP_DEPS {
            continue;
        }
        if isinstance(spec, str) {
            rng = spec.strip();
        } elif isinstance(spec, dict) {
            rng = str(spec.get("version", "")).strip();
        } else {
            continue;
        }
        reqs.append(make_pip_spec(pkg, rng));
    }
    return sorted(reqs);
}


def _emit_backend_jac_toml(backend_dir: Path, project_name: str, toml_data: dict) {
    byllm_cfg = toml_data.get("plugins", {}).get("byllm", {});
    if (not isinstance(byllm_cfg, dict)) or (not byllm_cfg) {
        return;
    }
    project_cfg = toml_data.get("project", {});
    version = str(project_cfg.get("version", "0.1.0"));
    lines: list[str] = [];
    _emit_toml_table(lines, "project", {"name": project_name, "version": version});
    _emit_toml_table(lines, "plugins.byllm", dict(byllm_cfg));
    (backend_dir / "jac.toml").write_text("\n".join(lines), encoding="utf-8");
    console.print("  ✔ byLLM config (jac.toml)", style="success");
}


def _emit_toml_table(lines: list, header: str, table: dict) {
    scalars: list = [];
    subs: list = [];
    for (k, v) in table.items() {
        if isinstance(v, dict) {
            subs.append((k, v));
        } else {
            scalars.append((k, v));
        }
    }
    if scalars {
        if header {
            lines.append("[" + header + "]");
        }
        for (k, v) in scalars {
            lines.append(str(k) + " = " + _toml_scalar(v));
        }
        lines.append("");
    }
    for (k, sub) in subs {
        child = (header + "." + str(k)) if header else str(k);
        _emit_toml_table(lines, child, dict(sub));
    }
}


def _toml_scalar(v: any) -> str {
    if isinstance(v, bool) {
        return "true" if v else "false";
    }
    if isinstance(v, str) {
        esc = v.replace("\\", "\\\\").replace('"', '\\"');
        return '"' + esc + '"';
    }
    if isinstance(v, (int, float)) {
        return str(v);
    }
    if isinstance(v, list) {
        return "[" + ", ".join([_toml_scalar(x) for x in v]) + "]";
    }
    return '"' + str(v).replace('"', '\\"') + '"';
}


def _emit_makefile(out: Path, has_frontend: bool) {
    lines: list[str] = ["BACKEND_PORT ?= 8000", ""];
    if has_frontend {
        lines += [
            ".PHONY: install dev dev-backend dev-frontend build start",
            "",
            "install:",
            "\tcd backend && pip install -r requirements.txt",
            "\tcd frontend && npm install",
            "",
            "dev:",
            "\t$(MAKE) -j2 dev-backend dev-frontend",
            "",
            "dev-backend:",
            "\tcd backend && uvicorn main:app --reload --port $(BACKEND_PORT)",
            "",
            "dev-frontend:",
            "\tcd frontend && BACKEND_PORT=$(BACKEND_PORT) npm run dev",
            "",
            "build:",
            "\tcd frontend && npm run build",
            "",
            "start: build",
            "\tcd backend && uvicorn main:app --host 0.0.0.0 --port $(BACKEND_PORT)",
            ""
        ];
    } else {
        lines += [
            ".PHONY: install dev start",
            "",
            "install:",
            "\tcd backend && pip install -r requirements.txt",
            "",
            "dev:",
            "\tcd backend && uvicorn main:app --reload --port $(BACKEND_PORT)",
            "",
            "start:",
            "\tcd backend && uvicorn main:app --host 0.0.0.0 --port $(BACKEND_PORT)",
            ""
        ];
    }
    (out / "Makefile").write_text("\n".join(lines), encoding="utf-8");
}


def _emit_readme(out: Path, project_name: str, has_frontend: bool, env_files: list) {
    layout = "`backend/` (FastAPI)";
    if has_frontend {
        layout += " + `frontend/` (Vite)";
    }
    lines: list[str] = [
        f"# {project_name}",
        "",
        f"Standalone app generated by `jac eject`: {layout}.",
        "The jaclang runtime is vendored into `backend/jaclang/`; "
        "no jaclang install is needed.",
        "",
        "## Quickstart",
        "",
        "```sh",
        "make install"
    ];
    if (".env.example" in env_files) and (".env" not in env_files) {
        lines.append("cp .env.example .env");
    }
    lines += ["make dev", "```", ""];
    if has_frontend {
        lines += [
            "`make dev` runs the backend on `http://localhost:8000` and the "
            "Vite dev server (with an API proxy) on `http://localhost:5173`. "
            "Override the backend port with `BACKEND_PORT=<port> make dev`.",
            "",
            "For a production-style run on a single origin (builds the "
            "frontend, then serves API + UI from the backend):",
            "",
            "```sh",
            "make start",
            "```",
            ""
        ];
    } else {
        lines += [
            "`make dev` runs the backend with auto-reload on "
            "`http://localhost:8000`. Override the port with "
            "`BACKEND_PORT=<port> make dev`; `make start` serves without "
            "reload on all interfaces.",
            ""
        ];
    }
    if env_files {
        lines += [
            "## Configuration",
            "",
            "Environment variables are loaded at startup from `.env` in this "
            "directory (or next to `backend/main.py`).",
            ""
        ];
    }
    lines += [
        "## API",
        "",
        "- Walkers: `POST /walker/<name>`; functions: `POST /function/<name>`.",
        "- Auth: `POST /user/register` and `POST /user/login`; `:pub` "
        "endpoints need no token.",
        "- OpenAPI docs at `/docs`; health check at `/__health`.",
        ""
    ];
    (out / "README.md").write_text("\n".join(lines), encoding="utf-8");
}


def _has_pub_access(ast_item: any) -> bool {
    import jaclang.jac0core.unitree as uni;
    import from jaclang.jac0core.constant { Tokens as Tok }
    if not isinstance(ast_item, uni.AstAccessNode) {
        return False;
    }
    access = ast_item?.access;
    if access is None {
        return False;
    }
    tag = access?.tag;
    if tag is None {
        return False;
    }
    return tag?.name == Tok.KW_PUB;
}
