"""Tests for the `jac browse` engine (`jaclang.cli.browser_engine`).

The transport tests drive a real `CDP.call()` through the actual RFC 6455
framing code against an in-process loopback server, so they need no Chrome:
client-side masking, the extended-length encodings, fragmentation, control
frames, and the `Sec-WebSocket-Accept` handshake check all run for real. The
remaining tests cover the Chrome-free engine logic directly: accessibility-tree
ref assignment, key-code mapping, and cookie projection.
"""

import base64;
import hashlib;
import json;
import os;
import socket;
import struct;
import tempfile;
import threading;
import time;
import from pathlib { Path }
import from jaclang.cli.browser_engine {
    CDP,
    connect,
    _walk_ax,
    _key_code,
    _cookie_param,
    _chrome_args,
    _parse_viewport,
    _format_console_event,
    _locate,
    cmd_wait
}


# ---------------------------------------------------------------------------
# Loopback WebSocket/CDP server (stands in for Chrome's DevTools endpoint)
# ---------------------------------------------------------------------------
def _recv_exact(conn: any, n: int) -> bytes {
    buf = bytearray();
    while len(buf) < n {
        chunk = conn.recv(n - len(buf));
        if not chunk {
            raise ConnectionError("client closed mid-frame");
        }
        buf.extend(chunk);
    }
    return bytes(buf);
}


"""Read one (masked) client frame and return its unmasked payload bytes."""
def _read_client_frame(conn: any) -> bytes {
    (b0, b1) = _recv_exact(conn, 2);
    masked = (b1 & 0x80) != 0;
    ln = b1 & 0x7F;
    if ln == 126 {
        ln = struct.unpack("!H", _recv_exact(conn, 2))[0];
    } elif ln == 127 {
        ln = struct.unpack("!Q", _recv_exact(conn, 8))[0];
    }
    mask = _recv_exact(conn, 4) if masked else bytes();
    payload = _recv_exact(conn, ln);
    if masked {
        payload = bytes([payload[i] ^ mask[i % 4] for i in range(ln)]);
    }
    return payload;
}


"""Send one server frame (server-to-client frames are never masked)."""
def _send_server_frame(conn: any, payload: bytes, opcode: int = 0x1, fin: bool = True) {
    header = bytearray([(0x80 if fin else 0x00) | opcode]);
    ln = len(payload);
    if ln < 126 {
        header.append(ln);
    } elif ln < 65536 {
        header.append(126);
        header.extend(struct.pack("!H", ln));
    } else {
        header.append(127);
        header.extend(struct.pack("!Q", ln));
    }
    conn.sendall(bytes(header) + payload);
}


"""Accept one connection and complete the WebSocket handshake."""
def _accept_ws(srv: socket.socket) -> socket.socket {
    conn = srv.accept()[0];
    conn.settimeout(10);
    req = bytearray();
    while "\r\n\r\n".encode() not in req {
        chunk = conn.recv(4096);
        if not chunk {
            return conn;
        }
        req.extend(chunk);
    }
    key = "";
    for line in bytes(req).decode().split("\r\n") {
        if line.lower().startswith("sec-websocket-key:") {
            key = line.split(":", 1)[1].strip();
        }
    }
    guid = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11";
    accept = base64.b64encode(hashlib.sha1((key + guid).encode()).digest()).decode();
    conn.sendall(
        (
            "HTTP/1.1 101 Switching Protocols\r\n"
            "Upgrade: websocket\r\n"
            "Connection: Upgrade\r\n"
            f"Sec-WebSocket-Accept: {accept}\r\n\r\n"
        ).encode()
    );
    return conn;
}


"""Answer one call in a single text frame."""
def _serve_one(srv: socket.socket, make_reply: any) {
    conn = _accept_ws(srv);
    request = json.loads(_read_client_frame(conn).decode());
    _send_server_frame(conn, json.dumps(make_reply(request)).encode());
}


"""Answer one call split across two frames (start + continuation)."""
def _serve_fragmented(srv: socket.socket, make_reply: any) {
    conn = _accept_ws(srv);
    request = json.loads(_read_client_frame(conn).decode());
    body = json.dumps(make_reply(request)).encode();
    mid = len(body) // 2;
    _send_server_frame(conn, body[:mid], opcode=0x1, fin=False);
    _send_server_frame(conn, body[mid:], opcode=0x0, fin=True);
}


"""Send a PING before the reply, then read the client's PONG."""
def _serve_with_ping(srv: socket.socket, make_reply: any) {
    conn = _accept_ws(srv);
    request = json.loads(_read_client_frame(conn).decode());
    _send_server_frame(conn, "ping".encode(), opcode=0x9, fin=True);
    _send_server_frame(conn, json.dumps(make_reply(request)).encode());
    _read_client_frame(conn);  # consume the PONG so the socket stays open for it
}


def _reply_small(req: dict) -> dict {
    return {"id": req["id"], "result": {"value": 42}};
}


def _reply_large(req: dict) -> dict {
    return {"id": req["id"], "result": {"value": "x" * 300, "echo": req["params"]}};
}


def _reply_error(req: dict) -> dict {
    return {"id": req["id"], "error": {"code": -32000, "message": "boom"}};
}


def _serve_in_thread(
    make_reply: any, serve_fn: any = _serve_one
) -> tuple[socket.socket, int, threading.Thread] {
    srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM);
    srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1);
    srv.bind(("127.0.0.1", 0));
    srv.listen(1);
    port = srv.getsockname()[1];
    t = threading.Thread(target=serve_fn, args=(srv, make_reply));
    t.start();
    return (srv, port, t);
}


def _connect_cdp(port: int) -> CDP {
    return CDP(ws_url=f"ws://127.0.0.1:{port}/devtools/page/X");
}


# ---------------------------------------------------------------------------
# Transport: WebSocket framing + CDP.call
# ---------------------------------------------------------------------------
test "CDP round-trips a JSON-RPC call over the hand-rolled WebSocket" {
    (srv, port, t) = _serve_in_thread(_reply_small);
    cdp = _connect_cdp(port);
    res = cdp.call("Runtime.evaluate", {"expression": "21+21"});
    assert res == {"value": 42};
    cdp.close();
    t.join(timeout=5);
    srv.close();
}


test "CDP handles extended-length frames in both directions" {
    (srv, port, t) = _serve_in_thread(_reply_large);
    cdp = _connect_cdp(port);
    # A >=126-byte expression forces the client's two-byte length send path;
    # the 300-byte reply forces the matching two-byte length recv path.
    big_expr = "y" * 200;
    res = cdp.call("Runtime.evaluate", {"expression": big_expr});
    assert len(res["value"]) == 300;
    assert res["echo"]["expression"] == big_expr;
    cdp.close();
    t.join(timeout=5);
    srv.close();
}


test "CDP reassembles a fragmented WebSocket message" {
    (srv, port, t) = _serve_in_thread(_reply_small, _serve_fragmented);
    cdp = _connect_cdp(port);
    res = cdp.call("Runtime.evaluate", {"expression": "1"});
    assert res == {"value": 42};
    cdp.close();
    t.join(timeout=5);
    srv.close();
}


test "CDP answers a server PING and still returns the reply" {
    (srv, port, t) = _serve_in_thread(_reply_small, _serve_with_ping);
    cdp = _connect_cdp(port);
    res = cdp.call("Runtime.evaluate", {"expression": "1"});
    assert res == {"value": 42};
    cdp.close();
    t.join(timeout=5);
    srv.close();
}


test "CDP surfaces a protocol error response as RuntimeError" {
    (srv, port, t) = _serve_in_thread(_reply_error);
    cdp = _connect_cdp(port);
    raised = False;
    try {
        cdp.call("Runtime.evaluate", {"expression": "boom"});
    } except RuntimeError as e {
        raised = True;
        assert "boom" in str(e);
    }
    assert raised , "a CDP error field must raise RuntimeError";
    cdp.close();
    t.join(timeout=5);
    srv.close();
}


test "connect raises when no live browser session exists" {
    tmp = tempfile.mkdtemp();
    old = os.environ.get("JACBROWSER_CACHE");
    os.environ["JACBROWSER_CACHE"] = tmp;
    try {
        raised = False;
        try {
            connect("nope");
        } except RuntimeError as e {
            raised = True;
            assert "no live browser" in str(e);
        }
        assert raised , "connect must reject a session with no state file";
    } finally {
        if old is None {
            del os.environ["JACBROWSER_CACHE"];
        } else {
            os.environ["JACBROWSER_CACHE"] = old;
        }
    }
}


# ---------------------------------------------------------------------------
# Engine logic (no Chrome, no socket)
# ---------------------------------------------------------------------------
test "_walk_ax assigns @e refs to interactive and named nodes only" {
    # WebArea
    #   button "Send"     -> interactive + backend            -> @e1
    #   heading "Welcome" -> named (non-interactive) + backend -> @e2
    #   generic           -> non-interactive, unnamed          -> no ref
    #   (ignored wrapper) -> emits nothing, child still walked
    #     link "Home"     -> interactive + backend             -> @e3
    #   textbox "Search"  -> interactive but no backend id     -> no ref
    nodes = {
        "1": {
            "nodeId": "1",
            "role": {"value": "WebArea"},
            "name": {"value": ""},
            "childIds": ["2", "3", "4", "5", "7"]
        },
        "2": {
            "nodeId": "2",
            "role": {"value": "button"},
            "name": {"value": "Send"},
            "backendDOMNodeId": 100,
            "childIds": []
        },
        "3": {
            "nodeId": "3",
            "role": {"value": "heading"},
            "name": {"value": "Welcome"},
            "backendDOMNodeId": 200,
            "childIds": []
        },
        "4": {
            "nodeId": "4",
            "role": {"value": "generic"},
            "name": {"value": ""},
            "backendDOMNodeId": 300,
            "childIds": []
        },
        "5": {
            "nodeId": "5",
            "ignored": True,
            "role": {"value": "presentation"},
            "childIds": ["6"]
        },
        "6": {
            "nodeId": "6",
            "role": {"value": "link"},
            "name": {"value": "Home"},
            "backendDOMNodeId": 400,
            "childIds": []
        },
        "7": {
            "nodeId": "7",
            "role": {"value": "textbox"},
            "name": {"value": "Search"},
            "childIds": []
        }
    };
    lines = [];
    refs = {};
    _walk_ax(nodes["1"], nodes, 0, lines, refs);

    assert refs == {"e1": 100, "e2": 200, "e3": 400};
    assert lines == [
        'WebArea',
        '  @e1 button "Send"',
        '  @e2 heading "Welcome"',
        '  generic',
        '  @e3 link "Home"',
        '  textbox "Search"'
    ];
}


test "_key_code maps letters and digits to DOM codes, passes through the rest" {
    assert _key_code("a") == "KeyA";
    assert _key_code("Z") == "KeyZ";
    assert _key_code("7") == "Digit7";
    assert _key_code("-") == "-";
    assert _key_code(".") == ".";
}


test "_cookie_param projects a CDP cookie to Network.setCookies shape" {
    full = _cookie_param(
        {
            "name": "sid",
            "value": "abc",
            "domain": "example.com",
            "path": "/app",
            "httpOnly": True,
            "secure": True,
            "expires": 1893456000.0,
            "sameSite": "Lax",
            "size": 99,
            "session": False
        }
    );
    assert full == {
        "name": "sid",
        "value": "abc",
        "domain": "example.com",
        "path": "/app",
        "httpOnly": True,
        "secure": True,
        "expires": 1893456000.0,
        "sameSite": "Lax"
    };

    # Session cookie: negative `expires` and missing `sameSite` are dropped,
    # and the domain/path/flag defaults are filled in.
    minimal = _cookie_param({"name": "t", "value": "1", "expires": -1});
    assert minimal == {
        "name": "t",
        "value": "1",
        "domain": "",
        "path": "/",
        "httpOnly": False,
        "secure": False
    };
}


# ---------------------------------------------------------------------------
# Launch configuration: viewport + software WebGL (issue #6597, gaps 3 + 4)
# ---------------------------------------------------------------------------
test "_parse_viewport accepts WxH forms and rejects garbage" {
    assert _parse_viewport("1280x720") == (1280, 720);
    assert _parse_viewport("800X600") == (800, 600);
    assert _parse_viewport("1024,768") == (1024, 768);
    raised = False;
    try {
        _parse_viewport("huge");
    } except ValueError {
        raised = True;
    }
    assert raised , "a non-WxH viewport spec must raise ValueError";
}


test "_chrome_args sets a real viewport and software WebGL, drops --disable-gpu" {
    args = _chrome_args("/usr/bin/chrome", Path("/tmp/profile-x"), "1280x720");
    assert args[0] == "/usr/bin/chrome";
    assert "--window-size=1280,720" in args;
    # SwiftShader software GL: without it headless WebGL contexts are null.
    assert "--use-angle=swiftshader" in args;
    assert "--enable-unsafe-swiftshader" in args;
    # --disable-gpu is what killed WebGL; it must be gone.
    assert "--disable-gpu" not in args;
    assert "--user-data-dir=/tmp/profile-x" in args;

    custom = _chrome_args("/usr/bin/chrome", Path("/tmp/profile-x"), "800x600");
    assert "--window-size=800,600" in custom;
}


# ---------------------------------------------------------------------------
# Console capture (issue #6597, gap 2)
# ---------------------------------------------------------------------------
test "_format_console_event formats console, exception, and log events" {
    line = _format_console_event(
        "Runtime.consoleAPICalled",
        {
            "type": "warning",
            "args": [
                {"type": "string", "value": "missing key"},
                {"type": "number", "value": 7},
                {
                    "type": "object",
                    "className": "HTMLDivElement",
                    "description": "div#root"
                }
            ]
        }
    );
    assert line == "[warning] missing key 7 div#root";

    exc = _format_console_event(
        "Runtime.exceptionThrown",
        {
            "exceptionDetails": {
                "text": "Uncaught",
                "exception": {"description": "TypeError: x is not a function"}
            }
        }
    );
    assert exc == "[error] TypeError: x is not a function";

    net = _format_console_event(
        "Log.entryAdded",
        {
            "entry": {
                "source": "network",
                "level": "error",
                "text": "404 Not Found",
                "url": "http://x/a.js",
                "lineNumber": 3
            }
        }
    );
    assert net == "[error] 404 Not Found (http://x/a.js:3)";

    # console-api log entries duplicate Runtime.consoleAPICalled; skip them.
    dup = _format_console_event(
        "Log.entryAdded",
        {"entry": {"source": "console-api", "level": "log", "text": "hi"}}
    );
    assert dup is None;

    # Unrelated CDP events are not console output.
    assert _format_console_event("Page.frameNavigated", {}) is None;
}


"""Serve many calls on one connection; replies come from `handler(req)`."""
def _serve_script(srv: socket.socket, handler: any) {
    conn = _accept_ws(srv);
    try {
        while True {
            req = json.loads(_read_client_frame(conn).decode());
            for msg in handler(req) {
                _send_server_frame(conn, json.dumps(msg).encode());
            }
        }
    } except Exception {
        # client closed the socket / sent a CLOSE frame
    }
}


"""Reply to Runtime.enable with its result plus replayed console/log events."""
def _console_replay_handler(req: dict) -> list {
    if req["method"] == "Runtime.enable" {
        return [
            {"id": req["id"], "result": {}},
            {
                "method": "Runtime.consoleAPICalled",
                "params": {
                    "type": "log",
                    "args": [{"type": "string", "value": "hello"}]
                }
            },
            {
                "method": "Log.entryAdded",
                "params": {
                    "entry": {"source": "network", "level": "error", "text": "boom"}
                }
            }
        ];
    }
    return [{"id": req["id"], "result": {}}];
}


test "CDP.drain_events collects event frames stashed around calls" {
    (srv, port, t) = _serve_in_thread(_console_replay_handler, _serve_script);
    cdp = _connect_cdp(port);
    cdp.call("Runtime.enable");
    # The replayed events land while waiting for this reply (stash path) ...
    cdp.call("Log.enable");
    # ... and drain_events returns them plus anything still in flight.
    events = cdp.drain_events(idle=0.3);
    methods = [e["method"] for e in events];
    assert "Runtime.consoleAPICalled" in methods;
    assert "Log.entryAdded" in methods;
    cdp.close();
    t.join(timeout=5);
    srv.close();
}


# ---------------------------------------------------------------------------
# Actionability: scroll-into-view + viewport/hit checks (issue #6597, gap 1)
# ---------------------------------------------------------------------------
glob _FN_DECLS: list = [];


def _actionability_replies(req: dict, state: dict) -> list {
    if req["method"] == "Runtime.evaluate" {
        return [{"id": req["id"], "result": {"result": {"objectId": "node-1"}}}];
    }
    if req["method"] == "Runtime.callFunctionOn" {
        _FN_DECLS.append(req["params"].get("functionDeclaration", ""));
        return [{"id": req["id"], "result": {"result": {"value": state}}}];
    }
    return [{"id": req["id"], "result": {}}];
}


def _onscreen_handler(req: dict) -> list {
    return _actionability_replies(
        req, {"ok": True, "x": 100.0, "y": 200.0, "hitOk": True, "hit": "input#below"}
    );
}


def _offscreen_handler(req: dict) -> list {
    return _actionability_replies(
        req,
        {"ok": False, "reason": "point (437,-1680) is outside the 1280x720 viewport"}
    );
}


def _intercepted_handler(req: dict) -> list {
    return _actionability_replies(
        req, {"ok": True, "x": 50.0, "y": 60.0, "hitOk": False, "hit": "div#overlay"}
    );
}


test "_locate scrolls into view, hit-tests, and returns a stable point" {
    _FN_DECLS.clear();
    (srv, port, t) = _serve_in_thread(_onscreen_handler, _serve_script);
    cdp = _connect_cdp(port);
    pt = _locate(cdp, "tsess", "#below", timeout=3.0);
    assert pt == (100.0, 200.0);
    # The in-page actionability check must scroll and hit-test for real.
    assert len(_FN_DECLS) >= 1;
    assert "scrollIntoView" in _FN_DECLS[0];
    assert "elementFromPoint" in _FN_DECLS[0];
    cdp.close();
    t.join(timeout=5);
    srv.close();
}


test "_locate hard-errors when the action point is outside the viewport" {
    (srv, port, t) = _serve_in_thread(_offscreen_handler, _serve_script);
    cdp = _connect_cdp(port);
    raised = False;
    try {
        _locate(cdp, "tsess", "#below", timeout=1.0);
    } except RuntimeError as e {
        raised = True;
        assert "outside the" in str(e);
    }
    assert raised , "an offscreen action point must be a hard error, not a no-op";
    cdp.close();
    t.join(timeout=5);
    srv.close();
}


test "_locate hard-errors when another element would receive the click" {
    (srv, port, t) = _serve_in_thread(_intercepted_handler, _serve_script);
    cdp = _connect_cdp(port);
    raised = False;
    try {
        _locate(cdp, "tsess", "#below", timeout=1.0);
    } except RuntimeError as e {
        raised = True;
        assert "div#overlay" in str(e);
    }
    assert raised , "a covered target must be a hard error, not a wrong click";
    cdp.close();
    t.join(timeout=5);
    srv.close();
}


# ---------------------------------------------------------------------------
# wait action (issue #6597, minor)
# ---------------------------------------------------------------------------
test "cmd_wait sleeps for a millisecond count without a browser" {
    start = time.time();
    out = cmd_wait("no-such-session", "120");
    assert time.time() - start >= 0.12;
    assert "120" in out;
}
