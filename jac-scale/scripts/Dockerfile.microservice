# Dockerfile template for jac-scale microservice mode.
#
# Single image, fanned out to one pod per service via JAC_SV_NAME env.
# KubernetesMicroserviceTarget sets the pod-spec command:
#   __gateway__ -> `jac scale gateway`
#   <svc>       -> `jac start <name>.jac` (with JAC_SV_SIBLING=1)
#
# Build + load into minikube:
#   eval $(minikube docker-env)
#   docker build -f Dockerfile.microservice -t myapp:dev .
#   jac start main.jac --scale

FROM python:3.12-slim

# git for pip VCS installs; curl for in-pod probe debug.
RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl \
    && rm -rf /var/lib/apt/lists/*

# Shared volumes (P0.25) may be owned by a UID that doesn't match the
# pod's UID (EFS CSI access points). Marking '*' safe bypasses git's
# CVE-2022-24765 dubious-ownership check on mounted dirs.
RUN git config --system --add safe.directory '*'

# jaclang ships as the self-contained `jac` binary (bundled CPython; not on
# PyPI). The official installer downloads it from GitHub Releases onto PATH;
# plugins are then added with the binary's own installer. The client framework
# now lives in jaclang core, so there is no separate jac-client to install.
# Pass `--version <jaseci-release>` to install.sh to pin and avoid dev/prod skew.
RUN curl -fsSL https://raw.githubusercontent.com/jaseci-labs/jaseci/main/scripts/install.sh \
    | bash \
    && cp "$HOME/.local/bin/jac" /usr/local/bin/jac \
    && jac install "jac-scale[deploy,data,tracing]" --global

WORKDIR /app
COPY . /app

# Install project pip deps from jac.toml [dependencies]; tolerate apps
# without any declared deps.
RUN if [ -f jac.toml ]; then jac install || true; fi

# Fail-loud check that the CLI is on PATH (runtime jaclang compiles .jac
# on first import anyway, so no pre-compile needed).
RUN jac --version

# Build identity (B-01): auto-build passes --build-arg JAC_BUILD_SHA
# (12-char git SHA, +`-dirty` on uncommitted changes); in-pod code reads it
# to report "running build X" with zero RBAC. Kept LAST for layer caching.
ARG JAC_BUILD_SHA=unknown
ENV JAC_BUILD_SHA=${JAC_BUILD_SHA}

# Pod-spec sets command + args; no ENTRYPOINT needed.
EXPOSE 8000
